GITHUB_TOKEN=
OLLAMA_URL=http://ollama:11434
CHROMA_HOST=http://chroma:8000
DEFAULT_LLM_MODEL=qwen2.5-coder:7b
OLLAMA_NUM_CTX=2048
EMBED_BATCH_SIZE=8
# ollama | fastembed | sentence_transformers (recommended for ingest speed)
EMBED_BACKEND=sentence_transformers
EMBED_LOCAL_MODEL=nomic-ai/nomic-embed-text-v1
EMBED_FAST_MODEL=nomic-ai/nomic-embed-text-v1.5-Q
EMBED_LOCAL_BATCH_SIZE=16
EMBED_FAST_BATCH_SIZE=32
EMBED_FAST_THREADS=0
EMBED_LOCAL_DEVICE=cpu
# Chunks held in RAM before embed+upsert; lower = less RAM, slower ingest
INGEST_FLUSH_SIZE=32
# Per-file and repo-wide chunk safety caps (0 = unlimited for that limit)
MAX_CHUNKS_PER_FILE=80
INGEST_MAX_TOTAL_CHUNKS=3000
AST_MAX_SLIDING_CHUNKS=40
DOC_MAX_SLIDING_CHUNKS=0
HTML_MAX_SLIDING_CHUNKS=20
NOTEBOOK_MAX_CELLS=100
MAX_INDEX_FILE_MB=2
CHROMA_UPSERT_BATCH_SIZE=32
EMBED_KEEP_ALIVE=5m
OLLAMA_CHAT_KEEP_ALIVE=10m
OLLAMA_READ_TIMEOUT=600
DEBUG_TIMING=false
RETRIEVAL_TIMEOUT=60
SMALL_CORPUS_THRESHOLD=20
MAX_REPO_SIZE_MB=500
LOG_LEVEL=info
BM25_CACHE_DIR=/bm25_cache
# Local host only — models stored in ./ollama_models/models (see scripts/start-ollama.sh)
OLLAMA_MODELS=./ollama_models/models
